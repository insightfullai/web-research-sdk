{
  "name": "web-research-sdk-workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "prepare": "vp config --hooks-dir .vite-hooks",
    "check": "vp check",
    "test": "vp run -r test",
    "build": "vp run -r build",
    "pack": "vp run -r pack",
    "pack:verify-exports": "node ./scripts/verify-package-exports.mjs",
    "pack:dry-run": "npm pack --dry-run --json --workspace @insightfull/web-research-sdk && npm pack --dry-run --json --workspace @insightfull/web-research-sdk-react",
    "clean": "vp run -r clean",
    "ready": "vp check && vp run -r test && vp run -r build",
    "release:check": "vp check && vp run -r test && vp run -r build && vp run -r pack && node ./scripts/verify-package-exports.mjs && npm pack --dry-run --json --workspace @insightfull/web-research-sdk && npm pack --dry-run --json --workspace @insightfull/web-research-sdk-react",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@types/node": "^24.6.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.0",
    "vite-plus": "^0.1.14",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "yarn@4.9.2"
}
