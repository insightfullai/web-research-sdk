{
  "name": "@insightfull/web-research-sdk",
  "version": "0.1.1",
  "description": "Core Insightfull Web Research SDK bridge and client runtime.",
  "homepage": "https://github.com/insightfullai/web-research-sdk#readme",
  "bugs": {
    "url": "https://github.com/insightfullai/web-research-sdk/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/insightfullai/web-research-sdk.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
