{
  "name": "@insightfull/web-research-sdk-react",
  "version": "0.1.0",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
