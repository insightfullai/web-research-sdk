{
  "name": "@insightfull/web-research-sdk-react",
  "version": "0.1.0",
  "description": "React integration primitives for the Insightfull Web Research SDK.",
  "homepage": "https://github.com/insightfullai/web-research-sdk#readme",
  "bugs": {
    "url": "https://github.com/insightfullai/web-research-sdk/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/insightfullai/web-research-sdk.git",
    "directory": "packages/react"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "pack": "vp pack",
    "test": "vp test run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@insightfull/web-research-sdk": "^0.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "jsdom": "^26.1.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
