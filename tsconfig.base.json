{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@insightfull/web-research-sdk": ["./packages/core/src/index.ts"],
      "@insightfull/web-research-sdk-react": ["./packages/react/src/index.ts"],
      "@insightfull/web-research-sdk-shared": ["./packages/shared/src/index.ts"],
      "@insightfull/web-research-sdk-contracts": ["./packages/contracts/src/index.ts"]
    }
  }
}
